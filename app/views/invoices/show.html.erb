<div class="min-h-screen bg-gray-100 flex flex-col md:flex-row">
  <!-- Sidebar -->
  <%= render "shared/sidebar" %>
  <div class="flex-1 flex flex-col">
    <!-- Navbar -->
    <%= render "shared/navbar" %>
    <main class="p-4 md:p-6">
      <div class="mt-6 md:mt-10 bg-white rounded-lg shadow-md p-4 md:p-6">
        <div class="w-full px-6">
          <!-- Invoice Details -->
          <div class="space-y-2 mb-6">
            <p class="font-bold mb-4"></p>
            <p><strong>Costomer Name:</strong> <%= @invoice.customer_name %></p>
            <p><strong>Invoice ID:</strong> <%= @invoice.id %></p>
            <p><strong>Date:</strong> <%= @invoice.created_at.strftime("%d %b %Y") %></p>
            <p><strong>Total Price:</strong> ₹<%= number_to_currency(@invoice.total_price, unit: "", precision: 2) %></p>
          </div>
          <!-- Invoice Items Table -->
          <div class="overflow-x-auto">
            <table class="min-w-full border border-gray-200 text-sm text-gray-700">
              <thead class="bg-gray-100">
                <tr>
                  <th class="px-4 py-2 border">Item</th>
                  <th class="px-4 py-2 border">Quantity</th>
                  <th class="px-4 py-2 border">Unit Price</th>
                  <th class="px-4 py-2 border">Subtotal</th>
                </tr>
              </thead>
              <tbody>
                <% @invoice.invoice_items.includes(:item).each do |invoice_item| %>
                  <tr>
                    <td class="px-4 py-2 border"><%= invoice_item.item.name %></td>
                    <td class="px-4 py-2 border text-center"><%= invoice_item.quantity %></td>
                    <td class="px-4 py-2 border text-center">₹<%= number_to_currency(invoice_item.price, unit: "", precision: 2) %></td>
                    <td class="px-4 py-2 border text-center">₹<%= number_to_currency(invoice_item.quantity * invoice_item.price, unit: "", precision: 2) %></td>
                  </tr>
                <% end %>
              </tbody>
              <tfoot>
                <tr class="bg-gray-50 font-bold">
                  <td colspan="3" class="px-4 py-2 border text-right">Total</td>
                  <td class="px-4 py-2 border text-center">₹<%= number_to_currency(@invoice.total_price, unit: "", precision: 2) %></td>
                </tr>
              </tfoot>
            </table>
          </div>
          <!-- Actions -->
          <div class="mt-6 flex space-x-3">
            <%= link_to "Edit", edit_invoice_path(@invoice), 
                  class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition" %>
            <%= link_to "Back to Invoices", invoices_path, 
                  class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition" %>
            <%= button_to "Delete", invoice_path(@invoice), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "inline-block bg-red-600 text-white px-4 py-3 rounded hover:bg-red-700 transition text-sm" %>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
